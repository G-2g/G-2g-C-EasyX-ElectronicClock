#include <stdio.h>
#include <time.h>
#include <windows.h>   // Sleep

int main() {
    while (1) {
        time_t rawtime;
        struct tm* timeinfo;
        time(&rawtime);
        timeinfo = localtime(&rawtime);
        printf("%02d:%02d:%02d\n", 
               timeinfo->tm_hour, timeinfo->tm_min, timeinfo->tm_sec);
        Sleep(1000);
    }
    return 0;
}
